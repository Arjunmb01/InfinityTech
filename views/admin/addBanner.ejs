<%- include('./partials/adminHeader.ejs') %>

    <div class="flex min-h-screen gradient-bg animate-gradient">
        <%- include('./partials/adminSidebar.ejs') %>

            <div class="flex-1 overflow-x-hidden overflow-y-auto" style="margin-left: var(--sidebar-width, 16rem);">
                <div class="container mx-auto px-6 py-8">
                    <!-- Header -->
                    <div class="flex justify-between items-center mb-8">
                        <h3
                            class="text-3xl font-extrabold bg-gradient-to-r from-[#d4af37] to-[#f9e076] bg-clip-text text-transparent">
                            Add New Banner
                        </h3>
                        <a href="/admin/banners" class="golden-button px-4 py-2 rounded-lg">
                            <i class="fas fa-arrow-left mr-2"></i> Back to Banners
                        </a>
                    </div>

                    <!-- Form -->
                    <div class="glass-effect rounded-2xl p-8 max-w-4xl mx-auto">
                        <form id="bannerForm" class="space-y-6">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="md:col-span-2">
                                    <label class="block text-sm font-medium text-white mb-2">Banner Title*</label>
                                    <input type="text" id="title" name="title" required
                                        class="w-full px-4 py-3 rounded-lg bg-[var(--content-bg)] border border-white/10 text-white">
                                </div>

                                <div class="md:col-span-2">
                                    <label class="block text-sm font-medium text-white mb-2">Description*</label>
                                    <textarea id="description" name="description" required rows="3"
                                        class="w-full px-4 py-3 rounded-lg bg-[var(--content-bg)] border border-white/10 text-white"></textarea>
                                </div>

                                <div>
                                    <label class="block text-sm font-medium text-white mb-2">Link URL</label>
                                    <input type="text" id="link" name="link" value="/shop"
                                        class="w-full px-4 py-3 rounded-lg bg-[var(--content-bg)] border border-white/10 text-white">
                                </div>

                                <div>
                                    <label class="block text-sm font-medium text-white mb-2">Button Text</label>
                                    <input type="text" id="buttonText" name="buttonText" value="Shop Now"
                                        class="w-full px-4 py-3 rounded-lg bg-[var(--content-bg)] border border-white/10 text-white">
                                </div>

                                <div>
                                    <label class="block text-sm font-medium text-white mb-2">Background Gradient</label>
                                    <select id="backgroundColor" name="backgroundColor"
                                        class="w-full px-4 py-3 rounded-lg bg-[var(--content-bg)] border border-white/10 text-white">
                                        <option value="from-blue-600 to-purple-600">Blue to Purple</option>
                                        <option value="from-green-600 to-teal-600">Green to Teal</option>
                                        <option value="from-red-600 to-pink-600">Red to Pink</option>
                                        <option value="from-yellow-600 to-orange-600">Yellow to Orange</option>
                                        <option value="from-indigo-600 to-blue-600">Indigo to Blue</option>
                                    </select>
                                </div>

                                <div>
                                    <label class="block text-sm font-medium text-white mb-2">Icon (FontAwesome)</label>
                                    <input type="text" id="icon" name="icon" value="fa-gift" placeholder="fa-gift"
                                        class="w-full px-4 py-3 rounded-lg bg-[var(--content-bg)] border border-white/10 text-white">
                                    <p class="text-xs text-gray-400 mt-1">e.g., fa-gift, fa-tag, fa-star</p>
                                </div>

                                <div>
                                    <label class="block text-sm font-medium text-white mb-2">Start Date</label>
                                    <input type="datetime-local" id="startDate" name="startDate"
                                        class="w-full px-4 py-3 rounded-lg bg-[var(--content-bg)] border border-white/10 text-white">
                                </div>

                                <div>
                                    <label class="block text-sm font-medium text-white mb-2">End Date (Optional)</label>
                                    <input type="datetime-local" id="endDate" name="endDate"
                                        class="w-full px-4 py-3 rounded-lg bg-[var(--content-bg)] border border-white/10 text-white">
                                </div>

                                <div>
                                    <label class="block text-sm font-medium text-white mb-2">Priority</label>
                                    <input type="number" id="priority" name="priority" value="0" min="0"
                                        class="w-full px-4 py-3 rounded-lg bg-[var(--content-bg)] border border-white/10 text-white">
                                    <p class="text-xs text-gray-400 mt-1">Higher priority banners appear first</p>
                                </div>

                                <div class="flex items-center">
                                    <input type="checkbox" id="isActive" name="isActive" checked
                                        class="h-4 w-4 text-[#d4af37] rounded">
                                    <label for="isActive" class="ml-2 text-white">Active</label>
                                </div>
                            </div>

                            <!-- Preview -->
                            <div class="mt-8">
                                <h4 class="text-lg font-semibold text-white mb-4">Preview</h4>
                                <div id="preview"
                                    class="bg-gradient-to-r from-blue-600 to-purple-600 text-white py-3 px-4 text-center text-sm rounded-lg">
                                    <p class="flex items-center justify-center gap-2">
                                        <i class="fas fa-gift"></i>
                                        <span><strong>Banner Title</strong> Banner description here. <a href="#"
                                                class="underline font-semibold">Shop Now</a></span>
                                    </p>
                                </div>
                            </div>

                            <div class="flex justify-end gap-4 mt-8">
                                <a href="/admin/banners"
                                    class="px-6 py-3 rounded-lg bg-gray-600 text-white hover:bg-gray-700">
                                    Cancel
                                </a>
                                <button type="submit"
                                    class="px-6 py-3 rounded-lg bg-gradient-to-r from-[#d4af37] to-[#f9e076] text-white">
                                    <i class="fas fa-save mr-2"></i> Create Banner
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Live preview
        function updatePreview() {
            const title = document.getElementById('title').value || 'Banner Title';
            const description = document.getElementById('description').value || 'Banner description here.';
            const buttonText = document.getElementById('buttonText').value || 'Shop Now';
            const backgroundColor = document.getElementById('backgroundColor').value;
            const icon = document.getElementById('icon').value || 'fa-gift';

            const preview = document.getElementById('preview');
            preview.className = `bg-gradient-to-r ${backgroundColor} text-white py-3 px-4 text-center text-sm rounded-lg`;
            preview.innerHTML = `
            <p class="flex items-center justify-center gap-2">
                <i class="fas ${icon}"></i>
                <span><strong>${title}</strong> ${description} <a href="#" class="underline font-semibold">${buttonText}</a></span>
            </p>
        `;
        }

        ['title', 'description', 'buttonText', 'backgroundColor', 'icon'].forEach(id => {
            document.getElementById(id).addEventListener('input', updatePreview);
        });

        // Form submission
        document.getElementById('bannerForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const formData = {
                title: document.getElementById('title').value,
                description: document.getElementById('description').value,
                link: document.getElementById('link').value,
                buttonText: document.getElementById('buttonText').value,
                backgroundColor: document.getElementById('backgroundColor').value,
                icon: document.getElementById('icon').value,
                startDate: document.getElementById('startDate').value || new Date().toISOString(),
                endDate: document.getElementById('endDate').value || null,
                priority: document.getElementById('priority').value,
                isActive: document.getElementById('isActive').checked
            };

            try {
                const response = await fetch('/admin/banners/add', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify(formData)
                });

                const data = await response.json();

                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Success!',
                        text: data.message,
                        timer: 1500,
                        showConfirmButton: false
                    }).then(() => {
                        window.location.href = '/admin/banners';
                    });
                } else {
                    Swal.fire('Error', data.message, 'error');
                }
            } catch (error) {
                Swal.fire('Error', 'Failed to create banner', 'error');
            }
        });
    </script>

    <%- include('./partials/adminFooter.ejs') %>