<%- include('./partials/adminHeader.ejs') %>

<style>
    /* Override conflicting styles */
    .products-container {
        display: block !important;
    }
    .product-grid {
        display: none !important;
    }
    .pagination-container {
        @apply mt-8 flex flex-col sm:flex-row items-center justify-between gap-4;
    }
    .pagination-button {
        @apply relative inline-flex items-center px-3 py-2 bg-[#0f1629]/80 backdrop-blur-md border border-white/10 text-sm text-[var(--text-color)] hover:bg-[#1e1b4b] transition-all duration-300;
    }
    .pagination-button.active {
        @apply bg-gradient-to-r from-[#F5C254] to-[#FFD666] text-[#020617] font-bold;
    }
    .flash-message {
        @apply px-4 py-2 rounded-lg mt-4 text-center bg-[#0f1629]/80 backdrop-blur-md border border-white/10;
    }
    .flash-success {
        @apply bg-green-500/20 text-green-400;
    }
    .flash-error {
        @apply bg-red-500/20 text-red-400;
    }
    tr:hover {
        @apply bg-[#1e1b4b]/50;
    }
</style>

<div class="flex min-h-screen gradient-bg animate-gradient">
    <%- include('./partials/adminSidebar.ejs') %>

    <!-- Main Content -->
    <main class="flex-1 overflow-x-hidden overflow-y-auto p-6" style="margin-left: var(--sidebar-width, 16rem);" role="main">
        <div class="container mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
            <!-- Header Section -->
            <div class="flex justify-between items-center mb-8 animate-fade-in-up">
                <h1 class="text-3xl font-extrabold bg-gradient-to-r from-[#F5C254] to-[#FFD666] bg-clip-text text-transparent tracking-tight" aria-label="Categories Management">Categories</h1>
                <a href="/admin/addCategory" 
                   class="inline-flex items-center px-4 py-2 rounded-lg bg-gradient-to-r from-[#F5C254] to-[#FFD666] text-[#020617] font-bold transition-all duration-300 transform hover:scale-105 group"
                   aria-label="Add New Category">
                    <svg class="w-5 h-5 mr-2 transition-transform duration-300 group-hover:rotate-12" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                    </svg>
                    Add New Category
                </a>
            </div>

            <!-- Search & Filter Form -->
            <form id="filterForm" class="flex flex-col sm:flex-row space-y-3 sm:space-y-0 sm:space-x-3 mb-6 animate-fade-in-up animation-delay-200">
                <input type="text" id="searchInput" name="search" placeholder="Search by name..." 
                       value="<%= search %>"
                       class="flex-1 px-4 py-3 rounded-lg bg-[#1e1b4b] border border-[#F5C254]/30 text-[var(--text-color)] placeholder-gray-500 focus:border-[#F5C254] focus:ring-2 focus:ring-[#F5C254]/20 transition-all duration-300">
                
                <select id="statusSelect" name="status" 
                        class="px-4 py-3 rounded-lg bg-[#1e1b4b] border border-[#F5C254]/30 text-[var(--text-color)] focus:border-[#F5C254] focus:ring-2 focus:ring-[#F5C254]/20 transition-all duration-300">
                    <option value="">All Status</option>
                    <option value="true" <%= status === "true" ? "selected" : "" %>>Active</option>
                    <option value="false" <%= status === "false" ? "selected" : "" %>>Inactive</option>
                </select>
        
                <select id="sortSelect" name="sort" 
                        class="px-4 py-3 rounded-lg bg-[#1e1b4b] border border-[#F5C254]/30 text-[var(--text-color)] focus:border-[#F5C254] focus:ring-2 focus:ring-[#F5C254]/20 transition-all duration-300">
                    <option value="date" <%= sort === "date" ? "selected" : "" %>>Newest First</option>
                    <option value="name" <%= sort === "name" ? "selected" : "" %>>Alphabetical</option>
                </select>
            </form>

            <!-- Categories Table -->
            <section class="glass-effect-dark rounded-xl p-6 shadow-xl border border-white/10 animate-fade-in-up animation-delay-400">
                <div class="overflow-x-auto relative">
                    <!-- Loader Overlay -->
                    <div id="tableLoader" class="absolute inset-0 bg-[#020617]/50 backdrop-blur-sm z-10 hidden items-center justify-center rounded-xl transition-all duration-300">
                        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-[#F5C254]"></div>
                    </div>

                    <table class="w-full" aria-label="Categories List">
                        <thead>
                            <tr class="border-b border-white/10">
                                <th class="px-6 py-4 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Category Name</th>
                                <th class="px-6 py-4 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Description</th>
                                <th class="px-6 py-4 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Status</th>
                                <th class="px-6 py-4 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="categoryTableBody" class="divide-y divide-white/10 transition-opacity duration-300">
                            <% if (categories && categories.length) { %>
                                <% categories.forEach(category => { %>
                                <tr class="transition-colors hover:bg-white/5" data-category-id="<%= category._id %>">
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-[var(--text-color)] font-medium">
                                        <%= category.name %>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-[var(--text-color)]">
                                        <%= category.description %>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span id="status-<%= category._id %>"
                                               class="inline-flex px-2 py-1 text-xs font-semibold leading-5 rounded-full
                                                      <%= category.status.isActive ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400' %>"
                                               role="status">
                                            <%= category.status.isActive ? 'Active' : 'Inactive' %>
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2">
                                        <a href="/admin/editCategory/<%= category._id %>"
                                           class="inline-flex items-center px-3 py-1.5 rounded-lg bg-[var(--content-bg)] text-[var(--text-color)] hover:bg-[var(--secondary-bg)] hover:text-white transition-all duration-300 transform hover:scale-105"
                                           aria-label="Edit Category">
                                            <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                            </svg>
                                            Edit
                                        </a>
                                        <button data-action="toggle" data-id="<%= category._id %>"
                                                id="toggle-<%= category._id %>"
                                                class="inline-flex items-center px-3 py-1.5 rounded-lg <%= category.status.isActive ? 'bg-red-600 hover:bg-red-500' : 'bg-[#d4af37] hover:bg-[#f9e076]' %> text-white transition-all duration-300 transform hover:scale-105"
                                                aria-label="<%= category.status.isActive ? 'Deactivate Category' : 'Activate Category' %>">
                                            <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                                      d="<%= category.status.isActive ? 'M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z' : 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' %>">
                                                </path>
                                            </svg>
                                            <%= category.status.isActive ? 'Deactivate' : 'Activate' %>
                                        </button>
                                    </td>
                                </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="4" class="text-center text-[var(--text-color)] py-8">
                                        <div class="flex flex-col items-center">
                                            <svg class="w-12 h-12 text-gray-500 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                            </svg>
                                            No categories found
                                        </div>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>

                    <!-- Pagination -->
                    <div id="paginationContainer" class="flex justify-between items-center mt-6 text-[var(--text-color)] transition-opacity duration-300">
                        <p id="paginationInfo">Page <%= currentPage %> of <%= totalPages %></p>
                        <div id="paginationLinks" class="space-x-2">
                            <% if (currentPage > 1) { %>
                                <button data-page="<%= currentPage - 1 %>" 
                                   class="px-3 py-2 bg-[var(--content-bg)] hover:bg-[var(--secondary-bg)] text-[var(--text-color)] rounded-lg transition-all duration-300 pagination-btn">
                                    Previous
                                </button>
                            <% } %>
                            <% if (currentPage < totalPages) { %>
                                <button data-page="<%= currentPage + 1 %>" 
                                   class="px-3 py-2 bg-[var(--content-bg)] hover:bg-[var(--secondary-bg)] text-[var(--text-color)] rounded-lg transition-all duration-300 pagination-btn">
                                    Next
                                </button>
                            <% } %>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </main>
</div>

<!-- SweetAlert2 for confirmations -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const tableBody = document.getElementById('categoryTableBody');
        const paginationContainer = document.getElementById('paginationContainer');
        const paginationInfo = document.getElementById('paginationInfo');
        const paginationLinks = document.getElementById('paginationLinks');
        const filterForm = document.getElementById('filterForm');
        const loader = document.getElementById('tableLoader');

        let currentSearch = '<%= search %>';
        let currentStatus = '<%= status %>';
        let currentSort = '<%= sort %>';
        let currentPage = <%= currentPage %>;

        // AJAX data loading
        async function loadCategories(page = 1) {
            loader.style.display = 'flex';
            tableBody.style.opacity = '0.5';
            paginationContainer.style.opacity = '0.5';

            const search = document.getElementById('searchInput').value;
            const status = document.getElementById('statusSelect').value;
            const sort = document.getElementById('sortSelect').value;

            const url = new URL(window.location.href);
            url.searchParams.set('page', page);
            url.searchParams.set('search', search);
            url.searchParams.set('status', status);
            url.searchParams.set('sort', sort);
            url.searchParams.set('ajax', 'true');

            try {
                const response = await fetch(url);
                const data = await response.json();

                if (data.success) {
                    renderTable(data.categories);
                    renderPagination(data.currentPage, data.totalPages);
                    
                    // Update URL without reload
                    const displayUrl = new URL(window.location.href);
                    displayUrl.searchParams.set('page', page);
                    displayUrl.searchParams.set('search', search);
                    displayUrl.searchParams.set('status', status);
                    displayUrl.searchParams.set('sort', sort);
                    window.history.pushState({}, '', displayUrl);
                    
                    currentPage = data.currentPage;
                }
            } catch (error) {
                console.error('Fetch error:', error);
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Failed to update category list'
                });
            } finally {
                loader.style.display = 'none';
                tableBody.style.opacity = '1';
                paginationContainer.style.opacity = '1';
            }
        }

        function renderTable(categories) {
            if (!categories.length) {
                tableBody.innerHTML = `
                    <tr>
                        <td colspan="4" class="text-center text-[var(--text-color)] py-8">
                            <div class="flex flex-col items-center">
                                <svg class="w-12 h-12 text-gray-500 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                                No categories found
                            </div>
                        </td>
                    </tr>
                `;
                return;
            }

            tableBody.innerHTML = categories.map(cat => `
                <tr class="transition-colors hover:bg-white/5" data-category-id="${cat._id}">
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-[var(--text-color)] font-medium">
                        ${cat.name}
                    </td>
                    <td class="px-6 py-4 text-sm text-[var(--text-color)]">
                        ${cat.description || ''}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span id="status-${cat._id}"
                               class="inline-flex px-2 py-1 text-xs font-semibold leading-5 rounded-full
                                      ${cat.status.isActive ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400'}"
                               role="status">
                            ${cat.status.isActive ? 'Active' : 'Inactive'}
                        </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2">
                        <a href="/admin/editCategory/${cat._id}"
                           class="inline-flex items-center px-3 py-1.5 rounded-lg bg-[var(--content-bg)] text-[var(--text-color)] hover:bg-[var(--secondary-bg)] hover:text-white transition-all duration-300 transform hover:scale-105"
                           title="Edit Category">
                            <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                            </svg>
                            Edit
                        </a>
                        <button data-action="toggle" data-id="${cat._id}"
                                id="toggle-${cat._id}"
                                class="inline-flex items-center px-3 py-1.5 rounded-lg ${cat.status.isActive ? 'bg-red-600 hover:bg-red-500' : 'bg-[#d4af37] hover:bg-[#f9e076]'} text-white transition-all duration-300 transform hover:scale-105">
                            <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                      d="${cat.status.isActive ? 'M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z' : 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z'}">
                                </path>
                            </svg>
                            ${cat.status.isActive ? 'Deactivate' : 'Activate'}
                        </button>
                    </td>
                </tr>
            `).join('');
        }

        function renderPagination(current, total) {
            paginationInfo.textContent = `Page ${current} of ${total}`;
            paginationLinks.innerHTML = '';
            
            if (current > 1) {
                paginationLinks.innerHTML += `
                    <button data-page="${current - 1}" class="px-3 py-2 bg-[var(--content-bg)] hover:bg-[var(--secondary-bg)] text-[var(--text-color)] rounded-lg transition-all duration-300 pagination-btn">
                        Previous
                    </button>
                `;
            }
            if (current < total) {
                paginationLinks.innerHTML += `
                    <button data-page="${current + 1}" class="px-3 py-2 bg-[var(--content-bg)] hover:bg-[var(--secondary-bg)] text-[var(--text-color)] rounded-lg transition-all duration-300 pagination-btn">
                        Next
                    </button>
                `;
            }
        }

        // Event listeners
        paginationLinks.addEventListener('click', (e) => {
            const btn = e.target.closest('.pagination-btn');
            if (btn) loadCategories(parseInt(btn.dataset.page));
        });

        // Search with debounce
        let debounceTimer;
        document.getElementById('searchInput').addEventListener('input', () => {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => loadCategories(1), 500);
        });

        // Filter selects
        ['statusSelect', 'sortSelect'].forEach(id => {
            document.getElementById(id).addEventListener('change', () => loadCategories(1));
        });

        // Action buttons delegation
        tableBody.addEventListener('click', (e) => {
            const button = e.target.closest('button');
            if (!button) return;
            if (button.dataset.action === 'toggle') toggleCategory(button.dataset.id);
        });
    });

    function toggleCategory(categoryId) {
        Swal.fire({
            title: 'Are you sure?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d4af37',
            cancelButtonColor: '#dc2626',
            confirmButtonText: 'Yes',
            background: 'var(--primary-bg)',
            color: 'var(--text-color)'
        }).then((result) => {
            if (result.isConfirmed) {
                fetch(`/admin/toggleCategoryStatus/${categoryId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' }
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire({ icon: 'success', title: 'Success!', text: data.message, timer: 1500, showConfirmButton: false });
                        // Re-load same page to reflect status
                        location.reload(); // Simple reload for toggle to keep logic clean, or loadCategories(currentPage)
                    } else throw new Error(data.message);
                })
                .catch(error => Swal.fire({ icon: 'error', title: 'Error', text: error.message }));
            }
        });
    }
</script>

<%- include('./partials/adminFooter.ejs') %>