<%- include('../partials/header') %>

<div class="bg-bg-primary min-h-screen py-24 flex items-center justify-center transition-colors duration-300">
    <div class="container mx-auto px-6 max-w-2xl">
        <div class="glass-card p-12 text-center relative overflow-hidden shadow-premium border-border-color">
            <!-- Animated Background Glow -->
            <div class="absolute -top-24 -right-24 w-64 h-64 bg-accent-vivid/10 blur-[100px] rounded-full"></div>
            <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-accent-vivid/5 blur-[100px] rounded-full"></div>

            <!-- Success Icon -->
            <div class="relative mb-10 inline-block">
                <div class="w-24 h-24 bg-accent-vivid/10 rounded-full flex items-center justify-center animate-pulse-slow">
                    <div class="w-16 h-16 bg-accent-vivid rounded-full flex items-center justify-center shadow-glow">
                        <i class="fas fa-check text-3xl text-white"></i>
                    </div>
                </div>
                <!-- Mini Floating Elements -->
                <div class="absolute -top-2 -right-2 w-4 h-4 bg-accent-vivid/20 rounded-full animate-float"></div>
                <div class="absolute bottom-0 -left-4 w-6 h-6 bg-accent-vivid/10 rounded-full animate-bounce [animation-duration:3s]"></div>
            </div>

            <!-- Content -->
            <h1 class="text-4xl font-black text-text-primary tracking-tighter uppercase mb-4">
                Purchase Confirmed
            </h1>
            <p class="text-sm font-medium text-text-muted mb-8 tracking-wide">
                Your high-performance tech is now being prepared for shipment.
            </p>

            <!-- Order Details Box -->
            <div class="bg-bg-secondary/50 rounded-2xl p-6 mb-10 border border-border-color text-left">
                <div class="flex justify-between items-center mb-4 pb-4 border-b border-white/5">
                    <span class="text-[10px] font-black text-text-muted uppercase tracking-widest">Order Reference</span>
                    <span class="text-sm font-black text-accent-vivid tracking-tighter">#<%= order._id %></span>
                </div>
                <div class="flex justify-between items-center mb-4">
                    <span class="text-[10px] font-black text-text-muted uppercase tracking-widest">Total Amount</span>
                    <span class="text-lg font-black text-text-primary tracking-tighter">₹<%= order.totalAmount.toLocaleString() %></span>
                </div>
                 <div class="flex justify-between items-center">
                    <span class="text-[10px] font-black text-text-muted uppercase tracking-widest">Payment Mode</span>
                    <span class="text-[10px] font-black text-text-primary uppercase tracking-widest bg-white/5 px-3 py-1 rounded-full"><%= order.paymentMethod %></span>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="/orders/<%= order._id %>" class="btn-premium px-8 py-4 flex items-center justify-center gap-3">
                    <i class="fas fa-box-open text-sm"></i>
                    Track Order
                </a>
                <a href="/shop" class="px-8 py-4 bg-white/5 hover:bg-white/10 rounded-xl font-bold text-text-primary border border-white/5 transition-all flex items-center justify-center gap-3">
                    <i class="fas fa-shopping-bag text-sm"></i>
                    Continue Shopping
                </a>
            </div>

            <!-- Redirect Hint -->
            <p class="mt-10 text-[9px] font-bold text-text-muted uppercase tracking-[0.3em] opacity-50">
                A confirmation has been sent to your registered email.
            </p>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
