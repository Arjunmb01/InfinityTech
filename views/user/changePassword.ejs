<!DOCTYPE html>
<html>
<head>
    <title>Forgot Password</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body {
            font-family: 'Poppins', sans-serif;
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
        }
        .btn-premium {
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
            color: white;
            border-radius: 12px;
            transition: all 0.3s ease;
        }
        .btn-premium:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px -5px rgba(79, 70, 229, 0.4);
        }
        .shadow-glow {
            box-shadow: 0 0 20px rgba(79, 70, 229, 0.2);
        }
    </style>
</head>
<body class="bg-slate-950 min-h-screen font-sans selection:bg-indigo-500/30 selection:text-indigo-200 flex items-center justify-center p-6">
    <!-- Background Decor -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden">
        <div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] bg-indigo-600/10 rounded-full blur-[120px] animate-pulse"></div>
        <div class="absolute -bottom-[10%] -right-[10%] w-[40%] h-[40%] bg-indigo-900/10 rounded-full blur-[120px] animate-pulse" style="animation-delay: 2s;"></div>
    </div>

    <div class="w-full max-w-md glass-card p-10 border-white/5 animate-fade-in relative z-10 transition-all">
        <div class="text-center mb-10">
            <a href="/" class="inline-block mb-8 group">
                <div class="flex items-center justify-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-indigo-600 flex items-center justify-center shadow-glow group-hover:scale-110 transition-transform">
                        <i class="fas fa-microchip text-white text-lg"></i>
                    </div>
                    <span class="text-2xl font-black text-white tracking-tighter uppercase tracking-[-0.05em]">Infinity<span class="text-indigo-500">Tech</span></span>
                </div>
            </a>
            <h1 class="text-3xl font-black text-white tracking-tighter uppercase mb-2">Key Recovery</h1>
            <p class="text-slate-500 text-sm font-medium">Initialize secondary credential verification.</p>
        </div>

        <form action="/user/forgotPassword" method="POST" class="space-y-6">
            <div>
                <label for="email" class="block text-[10px] font-black text-slate-500 uppercase tracking-[0.2em] mb-2 px-1">Identity (Email)</label>
                <div class="relative">
                    <input 
                        type="email" 
                        id="email" 
                        name="email" 
                        required
                        class="w-full bg-slate-900/50 border border-white/10 rounded-xl px-5 py-4 text-sm text-white placeholder-slate-600 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500/30 transition-all font-medium"
                        placeholder="Enter your registered email"
                    >
                </div>
            </div>

            <div class="pt-4">
                <button 
                    type="submit"
                    class="btn-premium w-full py-5 text-xs font-black uppercase tracking-[0.2em] shadow-glow"
                >
                    Broadcasting Signal
                </button>
            </div>
        </form>

        <div class="mt-10 text-center">
            <a href="/login" class="text-[10px] font-black text-indigo-400 hover:text-white uppercase tracking-widest transition-all underline decoration-indigo-500/20 underline-offset-4">
                Abort Protocol // Back to Login
            </a>
        </div>
    </div>

    <script>
        const form = document.querySelector('form');
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            const email = document.getElementById('email').value;
            
            fetch('/user/forgotPassword', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email })
            })
            .then(response => response.json())
            .then(data => {
                if (data.email) {
                    window.location.href = `/user/verifOtp?email=${encodeURIComponent(data.email)}`;
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('An error occurred. Please try again.');
            });
        });
    </script>
</body>
</html>