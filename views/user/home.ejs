<%- include('../partials/header') %>

    <!-- Dynamic Banner -->
    <% if (typeof banner !== 'undefined' && banner) { %>
        <div class="relative overflow-hidden bg-accent-primary/10 border-b border-border-color py-3 px-4 text-center">
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-accent-primary/5 to-transparent animate-pulse-slow"></div>
            <p class="relative flex items-center justify-center gap-3 text-sm font-medium text-text-primary tracking-wide">
                <span class="flex items-center gap-2 bg-accent-primary/20 px-2 py-0.5 rounded-md text-[10px] font-bold uppercase tracking-widest border border-accent-primary/30">
                    <i class="fas <%= banner.icon %>"></i> Exclusive
                </span>
                <span>
                    <strong class="font-bold text-accent-primary"><%= banner.title %>:</strong>
                    <%= banner.description %>
                    <a href="<%= banner.link %>" class="ml-2 inline-flex items-center gap-1 text-text-primary hover:text-accent-primary transition-colors group underline decoration-accent-primary/50 underline-offset-4">
                        <%= banner.buttonText %>
                        <i class="fas fa-chevron-right text-[10px] transform group-hover:translate-x-0.5 transition-transform"></i>
                    </a>
                </span>
            </p>
        </div>
    <% } %>

    <!-- Hero Section: Cinematic Full-bleed Background -->
    <section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden py-32 bg-bg-primary transition-colors duration-500">
        <!-- Hero Image as Background Layer -->
        <div class="absolute inset-0 z-0 overflow-hidden">
            <img src="/futuristic_laptop_hero_1775320178136.png" alt="Futuristic Tech Background" 
                class="w-full h-full object-cover opacity-20 dark:opacity-40 mix-blend-multiply dark:mix-blend-overlay animate-pulse-slow scale-110">
            <!-- Cinematic Gradients -->
            <div class="absolute inset-0 bg-gradient-to-b from-bg-primary via-bg-primary/40 to-bg-primary"></div>
            <div class="absolute inset-0 bg-gradient-to-r from-bg-primary via-transparent to-bg-primary"></div>
            <div class="absolute inset-0 bg-accent-primary/5 mix-blend-overlay"></div>
        </div>

        <!-- Abstract Light Effects -->
        <div class="absolute inset-0 z-0">
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[60%] h-[60%] bg-accent-primary/20 rounded-full blur-[160px] animate-pulse"></div>
            <div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] bg-accent-primary/5 rounded-full blur-[120px]"></div>
        </div>

        <!-- Centered Cinematic Hero Content -->
        <div class="container mx-auto px-6 relative z-10 text-center">
            <div x-data="{ loaded: false }" x-init="setTimeout(() => loaded = true, 100)" class="max-w-4xl mx-auto">
                <span x-show="loaded" 
                    x-transition:enter="transition ease-out duration-700" 
                    x-transition:enter-start="opacity-0 translate-y-4" 
                    x-transition:enter-end="opacity-100 translate-y-0"
                    class="inline-block py-1.5 px-6 rounded-full bg-accent-primary text-white text-[10px] font-black tracking-[0.4em] uppercase mb-12 shadow-glow">
                    Welcome to InfinityTech
                </span>
                
                <h1 x-show="loaded"
                    x-transition:enter="transition ease-out duration-1000 delay-100"
                    x-transition:enter-start="opacity-0 scale-95" 
                    x-transition:enter-end="opacity-100 scale-100"
                    class="text-6xl md:text-9xl font-black tracking-tighter text-text-primary mb-10 leading-[0.85] uppercase">
                    PRO <span class="text-gradient">PERFORMANCE</span>.<br>
                    <span class="text-gradient">MINIMAL DESIGN.</span>
                </h1>
                
                <p x-show="loaded"
                    x-transition:enter="transition ease-out duration-1000 delay-300"
                    class="text-lg md:text-xl text-text-secondary mb-16 max-w-2xl mx-auto font-bold leading-relaxed uppercase tracking-[0.1em]">
                    The intersection of high-fidelity power and architectural simplicity. The ultimate standard for professional creators.
                </p>
                
                <div x-show="loaded" 
                    x-transition:enter="transition ease-out duration-700 delay-500"
                    class="flex flex-col sm:flex-row items-center justify-center gap-8">
                    <a href="/shop" class="btn-premium px-12 py-5 text-xs font-black rounded-2xl tracking-[0.3em] uppercase shadow-glow hover:scale-105 active:scale-95 transition-all">
                        Shop Now
                    </a>
                    <a href="#featured" class="group flex items-center gap-4 text-text-primary text-[10px] font-black uppercase tracking-widest hover:text-accent-primary transition-all">
                        <span class="border-b border-border-color group-hover:border-accent-primary transition-all">View Collection</span>
                        <div class="w-10 h-10 rounded-xl border border-border-color flex items-center justify-center group-hover:border-accent-primary group-hover:bg-accent-primary/10 transition-all">
                            <i class="fas fa-chevron-down text-[10px] group-hover:translate-y-1 transition-transform"></i>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Featured Products -->
    <section id="featured" class="py-32 bg-bg-primary relative transition-colors duration-500">
        <div class="container mx-auto px-6 relative z-10 text-center mb-24">
            <h2 class="text-5xl font-black text-text-primary tracking-tighter mb-4 uppercase">
                Featured <span class="text-accent-primary">Collection</span>
            </h2>
            <div class="w-20 h-1.5 bg-accent-primary mx-auto rounded-full shadow-glow"></div>
        </div>

        <div class="container mx-auto px-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            <% if (typeof featuredProducts !== 'undefined' && featuredProducts.length > 0) { %>
                <% featuredProducts.forEach(function(product) { %>
                    <div class="group relative flex flex-col glass-card p-6 border-border-color transition-all duration-500 hover:border-accent-primary/30 hover:shadow-glow">
                        <div class="relative aspect-square rounded-2xl bg-bg-secondary overflow-hidden mb-8 flex items-center justify-center p-8 group-hover:bg-text-primary/[0.08] transition-all">
                            <% if (product.offerDetails && product.offerDetails.discountPercentage > 0) { %>
                                <div class="absolute top-4 left-4 bg-accent-primary text-white text-[10px] font-black px-3 py-1 rounded-full z-20 shadow-glow">
                                    -<%= Math.round(product.offerDetails.discountPercentage) %>%
                                </div>
                            <% } %>
                            
                            <a href="/product/<%= product._id %>" class="relative z-10 block transform group-hover:scale-110 transition-transform duration-700">
                                <img src="<%= product.images && product.images[0] ? product.images[0].url : '/images/placeholder.jpg' %>" alt="<%= product.name %>" class="max-w-full max-h-full object-contain filter drop-shadow-2xl grayscale brightness-110 hover:grayscale-0 transition-all">
                            </a>

                            <!-- Hover Interface -->
                            <div class="absolute inset-0 bg-bg-primary/80 opacity-0 group-hover:opacity-100 transition-all flex items-center justify-center gap-4 z-20 backdrop-blur-md">
                                <button onclick="toggleWishlist('<%= product._id %>', this)" 
                                    class="w-14 h-14 rounded-2xl bg-bg-secondary border border-border-color text-text-primary flex items-center justify-center hover:bg-text-primary hover:text-bg-primary transition-all transform hover:scale-110">
                                    <i class="far fa-heart text-lg"></i>
                                </button>
                                <button onclick="addToCart('<%= product._id %>')" 
                                    class="w-14 h-14 rounded-2xl bg-accent-primary text-white flex items-center justify-center hover:bg-text-primary hover:text-bg-primary transition-all transform hover:scale-110 shadow-glow">
                                    <i class="fas fa-cart-plus text-lg"></i>
                                </button>
                            </div>
                        </div>

                        <div class="space-y-4">
                            <div class="text-[10px] font-black text-accent-primary uppercase tracking-[0.3em]">
                                <%= product.category ? product.category.name : 'Hardware' %>
                            </div>
                            <a href="/product/<%= product._id %>" class="block">
                                <h3 class="text-xl font-bold text-text-primary group-hover:text-accent-primary transition-colors line-clamp-1 tracking-tight">
                                    <%= product.name %>
                                </h3>
                            </a>
                            <div class="flex items-center justify-between border-t border-border-color pt-6">
                                <div class="flex flex-col">
                                    <% if (product.offerDetails && product.offerDetails.discountPercentage > 0) { %>
                                        <span class="text-text-muted text-[10px] font-bold line-through mb-1">₹<%= product.offerDetails.originalPrice.toLocaleString('en-IN') %></span>
                                        <span class="text-2xl font-black text-text-primary tracking-tighter">₹<%= product.offerDetails.finalPrice.toLocaleString('en-IN', { maximumFractionDigits: 0 }) %></span>
                                    <% } else { %>
                                        <span class="text-2xl font-black text-text-primary tracking-tighter">₹<%= product.price.toLocaleString('en-IN') %></span>
                                    <% } %>
                                </div>
                                <div class="flex items-center gap-2 bg-bg-secondary px-3 py-1.5 rounded-xl border border-border-color">
                                    <i class="fas fa-star text-accent-primary text-[10px]"></i>
                                    <span class="text-xs font-black text-text-primary"><%= product.rating || '4.8' %></span>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </section>

    <!-- Values Section -->
    <section class="py-32 bg-bg-primary border-y border-border-color shadow-[0_0_100px_rgba(99,102,241,0.05)] transition-colors duration-500">
        <div class="container mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12">
            <div class="p-10 glass-card text-center group hover:bg-accent-primary/5 transition-all border-border-color hover:border-accent-primary/20">
                <div class="w-20 h-20 bg-accent-primary/10 rounded-3xl flex items-center justify-center mx-auto mb-8 text-accent-primary border border-accent-primary/20 shadow-glow group-hover:scale-110 transition-transform">
                    <i class="fas fa-shipping-fast text-3xl"></i>
                </div>
                <h3 class="text-xl font-black text-text-primary mb-4 tracking-tighter uppercase">Fast Shipping</h3>
                <p class="text-text-secondary text-sm font-bold leading-relaxed uppercase tracking-widest">Track your order anywhere in the world.</p>
            </div>
            <div class="p-10 glass-card text-center group hover:bg-accent-primary/5 transition-all border-border-color hover:border-accent-primary/20">
                <div class="w-20 h-20 bg-accent-primary/10 rounded-3xl flex items-center justify-center mx-auto mb-8 text-accent-primary border border-accent-primary/20 shadow-glow group-hover:scale-110 transition-transform">
                    <i class="fas fa-shield-halved text-3xl"></i>
                </div>
                <h3 class="text-xl font-black text-text-primary mb-4 tracking-tighter uppercase">Official Warranty</h3>
                <p class="text-text-secondary text-sm font-bold leading-relaxed uppercase tracking-widest">24 months of full hardware coverage.</p>
            </div>
            <div class="p-10 glass-card text-center group hover:bg-accent-primary/5 transition-all border-border-color hover:border-accent-primary/20">
                <div class="w-20 h-20 bg-accent-primary/10 rounded-3xl flex items-center justify-center mx-auto mb-8 text-accent-primary border border-accent-primary/20 shadow-glow group-hover:scale-110 transition-transform">
                    <i class="fas fa-rotate text-3xl"></i>
                </div>
                <h3 class="text-xl font-black text-text-primary mb-4 tracking-tighter uppercase">Easy Returns</h3>
                <p class="text-text-secondary text-sm font-bold leading-relaxed uppercase tracking-widest">30-day money-back guarantee.</p>
            </div>
        </div>
    </section>

    <!-- New Arrivals Section -->
    <section class="py-32 bg-bg-primary transition-colors duration-500">
        <div class="container mx-auto px-6 text-center mb-24">
            <h2 class="text-5xl font-black text-text-primary tracking-tighter mb-4 uppercase">
                New <span class="text-accent-primary">Arrivals</span>
            </h2>
            <div class="w-20 h-1.5 bg-accent-primary mx-auto rounded-full shadow-glow"></div>
        </div>

        <div class="container mx-auto px-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            <% if (typeof newArrivals !== 'undefined' && newArrivals.length > 0) { %>
                <% newArrivals.forEach(function(product) { %>
                    <div class="group relative flex flex-col glass-card p-6 border-border-color transition-all duration-500 hover:border-accent-primary/30">
                        <div class="relative aspect-square rounded-2xl bg-bg-secondary overflow-hidden mb-8 flex items-center justify-center p-8 group-hover:bg-text-primary/[0.08] transition-all">
                            <a href="/product/<%= product._id %>" class="relative z-10 block transform group-hover:scale-110 transition-transform duration-700">
                                <img src="<%= product.images && product.images[0] ? product.images[0].url : '/images/placeholder.jpg' %>" alt="<%= product.name %>" class="max-w-full max-h-full object-contain filter drop-shadow-2xl">
                            </a>
                            <div class="absolute inset-0 bg-bg-primary/80 opacity-0 group-hover:opacity-100 transition-all flex items-center justify-center gap-4 z-20 backdrop-blur-md">
                                <button onclick="toggleWishlist('<%= product._id %>', this)" class="w-14 h-14 rounded-2xl bg-bg-secondary border border-border-color text-text-primary flex items-center justify-center hover:bg-text-primary hover:text-bg-primary transition-all transform hover:scale-110">
                                    <i class="far fa-heart text-lg"></i>
                                </button>
                                <button onclick="addToCart('<%= product._id %>')" class="w-14 h-14 rounded-2xl bg-accent-primary text-white flex items-center justify-center hover:bg-text-primary hover:text-bg-primary transition-all transform hover:scale-110 shadow-glow">
                                    <i class="fas fa-cart-plus text-lg"></i>
                                </button>
                            </div>
                        </div>
                        <div class="space-y-4">
                            <a href="/product/<%= product._id %>" class="block">
                                <h3 class="text-xl font-bold text-text-primary group-hover:text-accent-primary transition-colors line-clamp-1 tracking-tight">
                                    <%= product.name %>
                                </h3>
                            </a>
                            <div class="flex items-center justify-between border-t border-border-color pt-6">
                                <span class="text-2xl font-black text-text-primary tracking-tighter">₹<%= (product.offerDetails ? product.offerDetails.finalPrice : product.price).toLocaleString('en-IN', { maximumFractionDigits: 0 }) %></span>
                                <div class="bg-accent-primary/10 px-3 py-1.5 rounded-xl border border-accent-primary/20">
                                    <span class="text-[10px] font-black text-accent-primary uppercase tracking-widest">New</span>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </section>

    <%- include('../partials/footer') %>

    <style>
        .animate-float { animation: float 6s ease-in-out infinite; }
        .animate-float-reverse { animation: float-reverse 8s ease-in-out infinite; }
        .animate-float-slow { animation: float 10s ease-in-out infinite; }
        .animate-pulse-slow { animation: pulse 12s ease-in-out infinite; }
 
        @keyframes float {
            0%, 100% { transform: translateY(0) rotate(0); }
            50% { transform: translateY(-20px) rotate(5deg); }
        }
 
        @keyframes float-reverse {
            0%, 100% { transform: translateY(0) rotate(0); }
            50% { transform: translateY(20px) rotate(-5deg); }
        }
 
        @keyframes pulse {
            0%, 100% { opacity: 0.3; transform: scale(1.1); }
            50% { opacity: 0.4; transform: scale(1.15); }
        }
 
        .shadow-glow { box-shadow: 0 0 20px var(--accent-glow); }
        .text-gradient { 
            background: var(--premium-gradient); 
            -webkit-background-clip: text; 
            -webkit-text-fill-color: transparent; 
        }
    </style>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        async function addToCart(productId) {
            try {
                const response = await fetch('/api/cart/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId, quantity: 1 })
                });
                const data = await response.json();
                if (data.success) {
                    Swal.fire({ toast: true, position: 'bottom-end', icon: 'success', title: 'Added to cart', showConfirmButton: false, timer: 3000 });
                    const countBadge = document.getElementById('cart-count');
                    if (countBadge) countBadge.innerText = data.cartCount;
                } else {
                    if (data.message === 'Please login to continue') window.location.href = '/login';
                    else Swal.fire({ toast: true, position: 'bottom-end', icon: 'error', title: data.message || 'Error', timer: 3000 });
                }
            } catch (error) { console.error(error); }
        }

        async function toggleWishlist(productId, btnElement) {
            try {
                const response = await fetch('/api/wishlist/toggle', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId })
                });
                const data = await response.json();
                const icon = btnElement.querySelector('i');
                if (data.success) {
                    if (data.action === 'added') {
                        icon.classList.remove('far'); icon.classList.add('fas', 'text-red-500');
                        Swal.fire({ toast: true, position: 'bottom-end', icon: 'success', title: 'Added to wishlist', showConfirmButton: false, timer: 2000 });
                    } else {
                        icon.classList.remove('fas', 'text-red-500'); icon.classList.add('far');
                        Swal.fire({ toast: true, position: 'bottom-end', icon: 'success', title: 'Removed from wishlist', showConfirmButton: false, timer: 2000 });
                    }
                    const countBadge = document.getElementById('wishlist-count');
                    if (countBadge) { countBadge.innerText = data.wishlistCount; countBadge.classList.remove('hidden'); }
                } else {
                    if (data.message === 'Please login to continue') window.location.href = '/login';
                    else Swal.fire({ toast: true, position: 'bottom-end', icon: 'error', title: data.message || 'Error', timer: 3000 });
                }
            } catch (error) { console.error(error); }
        }
    </script>