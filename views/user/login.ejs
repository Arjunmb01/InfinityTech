<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In - InfinityTech</title>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100;300;400;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Outfit', sans-serif; }
        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 2rem;
        }
        .btn-premium {
            background: #6366f1;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }
        .btn-premium:hover {
            background: #4f46e5;
            box-shadow: 0 0 30px rgba(99, 102, 241, 0.4);
            transform: translateY(-2px);
        }
        .shadow-glow {
            box-shadow: 0 0 40px rgba(99, 102, 241, 0.2);
        }
    </style>
</head>

<body class="bg-[#09090b] min-h-screen selection:bg-indigo-500/30 selection:text-indigo-200">
    <!-- Background Decor -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden">
        <div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] bg-indigo-600/5 rounded-full blur-[120px] animate-pulse"></div>
        <div class="absolute -bottom-[10%] -right-[10%] w-[40%] h-[40%] bg-indigo-900/5 rounded-full blur-[120px] animate-pulse" style="animation-delay: 2s;"></div>
    </div>

    <div class="flex min-h-screen items-center justify-center p-6 relative z-10">
        <!-- Login Card -->
        <div class="w-full max-w-md glass-card p-10 border-white/5">
            <div class="text-center mb-10">
                <a href="/" class="inline-block mb-10 group">
                    <div class="flex items-center gap-3">
                        <div class="w-12 h-12 rounded-2xl bg-indigo-600 flex items-center justify-center shadow-glow group-hover:scale-110 transition-transform">
                            <i class="fas fa-microchip text-white text-xl"></i>
                        </div>
                        <span class="text-2xl font-black text-white tracking-tighter uppercase">Infinity<span class="text-indigo-500">Tech</span></span>
                    </div>
                </a>
                <h1 class="text-3xl font-black text-white tracking-tighter uppercase mb-2">Welcome <span class="text-indigo-500">Back</span></h1>
                <p class="text-slate-600 text-[10px] font-black uppercase tracking-[0.3em]">Sign in to your account to continue</p>
            </div>

            <!-- Flash Messages -->
            <% if (messages.error && messages.error.length > 0) { %>
                <div class="mb-8 p-4 rounded-2xl bg-red-500/10 border border-red-500/20 text-red-400 text-[10px] font-black uppercase tracking-widest flex items-center gap-3">
                    <i class="fas fa-exclamation-circle text-red-500"></i>
                    <%= messages.error[0] %>
                </div>
            <% } else if (messages.success && messages.success.length > 0) { %>
                <div class="mb-8 p-4 rounded-2xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-[10px] font-black uppercase tracking-widest flex items-center gap-3">
                    <i class="fas fa-check-circle text-emerald-500"></i>
                    <%= messages.success[0] %>
                </div>
            <% } %>

            <form id="login-form" class="space-y-6" method="POST" action="/login">
                <div class="space-y-6">
                    <div>
                        <label for="email" class="block text-[10px] font-black text-slate-500 uppercase tracking-[0.2em] mb-3 ml-1">Email Address</label>
                        <input id="email" name="email" type="email" autocomplete="email" required
                            class="w-full bg-[#0a0a0a] border border-white/10 rounded-2xl px-6 py-4 text-xs font-bold text-white placeholder-slate-800 transition-all focus:ring-2 focus:ring-indigo-500/30"
                            placeholder="e.g. user@example.com"
                            value="<%= locals.email || '' %>">
                        <p id="emailError" class="hidden text-red-500 text-[9px] font-black uppercase tracking-widest mt-2 px-1"></p>
                    </div>

                    <div>
                        <div class="flex items-center justify-between mb-3 px-1">
                            <label for="password" class="block text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]">Password</label>
                            <a href="/forgotPassword" class="text-[9px] font-black text-indigo-500 hover:text-white uppercase tracking-widest transition-all">Forgot?</a>
                        </div>
                        <div class="relative">
                            <input id="password" name="password" type="password" autocomplete="current-password" required
                                class="w-full bg-[#0a0a0a] border border-white/10 rounded-2xl px-6 py-4 text-xs font-bold text-white placeholder-slate-800 transition-all focus:ring-2 focus:ring-indigo-500/30"
                                placeholder="••••••••">
                            <button type="button" onclick="togglePassword('password', 'toggleIcon')"
                                class="absolute right-6 top-1/2 -translate-y-1/2 text-slate-700 hover:text-white transition-colors">
                                <i id="toggleIcon" class="far fa-eye text-xs"></i>
                            </button>
                        </div>
                        <p id="passwordError" class="hidden text-red-500 text-[9px] font-black uppercase tracking-widest mt-2 px-1"></p>
                    </div>
                </div>

                <div class="flex items-center px-1">
                    <input id="remember-me" name="remember-me" type="checkbox"
                        class="w-4 h-4 rounded border-white/10 bg-[#0a0a0a] text-indigo-600 focus:ring-indigo-500/30 transition-all cursor-pointer">
                    <label for="remember-me" class="ml-3 block text-[9px] font-black text-slate-600 uppercase tracking-widest cursor-pointer hover:text-white transition-all">Remember Me</label>
                </div>

                <div class="pt-4">
                    <button type="submit" class="btn-premium w-full py-5 text-[11px] font-black uppercase tracking-[0.3em] rounded-2xl shadow-glow text-white border-none cursor-pointer">
                        Sign In
                    </button>
                </div>

                <div class="relative py-6">
                    <div class="absolute inset-0 flex items-center">
                        <div class="w-full border-t border-white/5"></div>
                    </div>
                    <div class="relative flex justify-center text-[9px] font-black uppercase tracking-[0.3em]">
                        <span class="px-6 bg-[#09090b] text-slate-800">Or Continue With</span>
                    </div>
                </div>

                <a href="/auth/google"
                    class="flex items-center justify-center w-full px-8 py-4 bg-white/5 border border-white/10 rounded-2xl text-[10px] font-black text-white hover:bg-white hover:text-[#09090b] transition-all group uppercase tracking-widest">
                    <i class="fab fa-google text-indigo-500 mr-4 group-hover:text-[#09090b] transition-colors"></i> Google Account
                </a>
            </form>

            <div class="mt-12 text-center">
                <p class="text-[10px] font-black text-slate-700 uppercase tracking-widest">
                    New to InfinityTech?
                    <a href="/signup" class="text-indigo-500 hover:text-white transition-all ml-2 underline underline-offset-8 decoration-indigo-500/20">Create Account</a>
                </p>
            </div>
        </div>

        <a href="/" class="absolute top-10 right-10 w-12 h-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-slate-700 hover:text-white hover:bg-red-500/10 hover:border-red-500/50 transition-all group">
            <i class="fas fa-times text-lg group-hover:rotate-90 transition-transform"></i>
        </a>
    </div>

    <script>
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }
    </script>
</body>

</html>