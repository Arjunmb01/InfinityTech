<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify OTP - InfinityTech</title>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100;300;400;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Outfit', sans-serif; }
        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 2.5rem;
        }
        .btn-premium {
            background: #6366f1;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }
        .btn-premium:hover {
            background: #4f46e5;
            box-shadow: 0 0 30px rgba(99, 102, 241, 0.4);
            transform: translateY(-2px);
        }
        .shadow-glow {
            box-shadow: 0 0 40px rgba(99, 102, 241, 0.2);
        }
        .otp-input:focus {
            box-shadow: 0 0 30px rgba(99, 102, 241, 0.15);
        }
    </style>
</head>

<body class="bg-[#09090b] min-h-screen selection:bg-indigo-500/30 selection:text-indigo-200">
    <!-- Background Decor -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden">
        <div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] bg-indigo-600/5 rounded-full blur-[120px] animate-pulse"></div>
        <div class="absolute -bottom-[10%] -right-[10%] w-[40%] h-[40%] bg-indigo-900/5 rounded-full blur-[120px] animate-pulse" style="animation-delay: 2s;"></div>
    </div>

    <div class="flex min-h-screen items-center justify-center p-6 relative z-10">
        <!-- Auth Card -->
        <div class="w-full max-w-md glass-card p-10 border-white/5">
            <div class="text-center mb-10">
                <a href="/" class="inline-block mb-10 group">
                    <div class="flex items-center gap-3">
                        <div class="w-12 h-12 rounded-2xl bg-indigo-600 flex items-center justify-center shadow-glow group-hover:scale-110 transition-transform">
                            <i class="fas fa-microchip text-white text-xl"></i>
                        </div>
                        <span class="text-2xl font-black text-white tracking-tighter uppercase">Infinity<span class="text-indigo-500">Tech</span></span>
                    </div>
                </a>
                <h1 class="text-3xl font-black text-white tracking-tighter uppercase mb-2">Verify <span class="text-indigo-500">Email</span></h1>
                <p class="text-slate-600 text-[10px] font-black uppercase tracking-[0.3em]">Code sent to: <span class="text-indigo-400"><%= email %></span></p>
            </div>

            <form id="otpForm" class="space-y-10">
                <div>
                    <label for="otp" class="block text-[10px] font-black text-slate-500 uppercase tracking-[0.2em] mb-6 text-center">Enter 6-Digit Verification Code</label>
                    <input type="text" id="otp" name="otp" maxlength="6" required
                        class="otp-input w-full bg-[#0a0a0a] border border-white/10 rounded-3xl px-6 py-8 text-5xl text-white text-center font-black tracking-[0.4em] focus:outline-none focus:ring-2 focus:ring-indigo-500/30 transition-all placeholder-slate-900"
                        placeholder="000000">
                    <p id="otpError" class="hidden text-red-500 text-[9px] font-black uppercase tracking-widest mt-4 text-center px-1"></p>
                </div>

                <div class="flex flex-col items-center gap-8">
                    <div class="flex items-center gap-4 bg-white/5 px-6 py-3 rounded-full border border-white/5">
                        <div class="w-2 h-2 rounded-full bg-indigo-500 animate-ping"></div>
                        <span class="text-[10px] font-black text-slate-500 uppercase tracking-widest leading-none">
                            Code Expires In: <span id="timer" class="text-white font-mono">01:00</span>
                        </span>
                    </div>
                    
                    <button type="button" id="resendButton" disabled
                        class="text-[10px] font-black text-indigo-500 hover:text-white disabled:text-slate-800 disabled:cursor-not-allowed uppercase tracking-widest transition-all">
                        Resend Code
                    </button>
                </div>

                <div class="pt-4">
                    <button type="submit" class="btn-premium w-full py-5 text-[11px] font-black uppercase tracking-[0.3em] rounded-2xl shadow-glow text-white border-none cursor-pointer">
                        Verify Account
                    </button>
                </div>
            </form>

            <div class="mt-12 text-center">
                <p class="text-[10px] font-black text-slate-700 uppercase tracking-widest">
                    Wrong Email Address?
                    <a href="/signup" class="text-indigo-500 hover:text-white transition-all ml-2 underline underline-offset-8 decoration-indigo-500/20">Change Email</a>
                </p>
            </div>
        </div>

        <a href="/" class="absolute top-10 right-10 w-12 h-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-slate-700 hover:text-white hover:bg-red-500/10 hover:border-red-500/50 transition-all group shadow-xl">
            <i class="fas fa-times text-lg group-hover:rotate-90 transition-transform"></i>
        </a>
    </div>

    <script>
        let timeLeft = 60;
        let timerId = null;

        function startTimer() {
            const timerDisplay = document.getElementById('timer');
            const resendButton = document.getElementById('resendButton');
            resendButton.disabled = true;

            timerId = setInterval(() => {
                timeLeft--;
                const minutes = Math.floor(timeLeft / 60);
                const seconds = timeLeft % 60;
                timerDisplay.textContent = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;

                if (timeLeft <= 0) {
                    clearInterval(timerId);
                    resendButton.disabled = false;
                    timerDisplay.textContent = "00:00";
                }
            }, 1000);
        }

        startTimer();

        document.getElementById('otpForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            const otp = document.getElementById('otp').value.trim();
            const otpError = document.getElementById('otpError');
            otpError.classList.add('hidden');

            if (!otp || !/^\d{6}$/.test(otp)) {
                otpError.textContent = 'Invalid code format';
                otpError.classList.remove('hidden');
                return;
            }

            try {
                const response = await fetch('/verifyOtp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ otp })
                });
                const result = await response.json();

                if (!result.success) {
                    Swal.fire({
                        icon: 'error', title: 'Invalid Code', text: result.message,
                        background: '#0a0a0a', color: '#fff', confirmButtonColor: '#6366f1'
                    });
                    if (result.redirect) setTimeout(() => window.location.href = result.redirect, 3000);
                } else {
                    Swal.fire({
                        icon: 'success', title: 'Verified!', text: result.message,
                        timer: 2000, showConfirmButton: false, background: '#0a0a0a', color: '#fff'
                    }).then(() => window.location.href = result.redirect);
                }
            } catch (error) {
                Swal.fire({
                    icon: 'error', title: 'Connection Error', text: 'Check your internet link.',
                    background: '#0a0a0a', color: '#fff'
                });
            }
        });

        document.getElementById('resendButton').addEventListener('click', async function () {
            try {
                const response = await fetch('/resendOtp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                const result = await response.json();

                if (result.success) {
                    timeLeft = 60;
                    clearInterval(timerId);
                    startTimer();
                    Swal.fire({
                        icon: 'success', 
                        title: result.devOtp ? `DEV CODE: ${result.devOtp}` : 'Code Resent', 
                        text: result.message,
                        timer: 5000, showConfirmButton: true, background: '#0a0a0a', color: '#fff'
                    });
                } else {
                    Swal.fire({
                        icon: 'error', title: 'Failed', text: result.message,
                        background: '#0a0a0a', color: '#fff'
                    });
                }
            } catch (error) {
                Swal.fire({
                    icon: 'error', title: 'Error', text: 'Request failed.',
                    background: '#0a0a0a', color: '#fff'
                });
            }
        });

        const otpInput = document.getElementById('otp');
        otpInput.addEventListener('input', (e) => {
            e.target.value = e.target.value.replace(/\D/g, '');
        });
    </script>
</body>

</html>